# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Prisma / SQLite database path (relative to apps/api)
DATABASE_URL="file:./dev.db"

# NestJS API port
PORT=3001

# JWT secret — use a long random string in production
JWT_SECRET="dev-change-me"

# Frontend origin allowed by CORS
CORS_ORIGIN="http://localhost:3000"

# URL of the web app (used for redirects)
WEB_APP_URL="http://localhost:3000"

# Zerodha Kite Connect — must match the redirect URL set in your Kite app console
KITE_REDIRECT_URL="http://localhost:3001/brokers/kite/callback"

# Kite Connect API credentials — get them from https://kite.trade/
KITE_API_KEY="your_kite_api_key_here"
KITE_API_SECRET="your_kite_api_secret_here"

# ── WhatsApp notifications via Twilio ────────────────────────────────────────
# Leave blank to disable WhatsApp alerts entirely.
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# Sandbox: whatsapp:+14155238886  |  Production: whatsapp:+91XXXXXXXXXX
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Recipient phone number (must have joined the sandbox in dev)
TWILIO_WHATSAPP_TO="whatsapp:+91XXXXXXXXXX"
