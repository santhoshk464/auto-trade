generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  phone              String?
  passwordHash       String
  role               Role                @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  brokers            Broker[]
  liveTrades         LiveTrade[]
  paperTrades        PaperTrade[]
  passwordResetToken PasswordResetToken?
  signals            Signal[]
  trades             Trade[]
  tradingSettings    TradingSettings[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Broker {
  id                   String            @id @default(cuid())
  userId               String
  type                 BrokerType
  name                 String
  apiKey               String
  apiSecret            String
  accessToken          String?
  accessTokenExpiresAt DateTime?
  lastConnectedAt      DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveTrades           LiveTrade[]
  paperTrades          PaperTrade[]
  signals              Signal[]
  strikeSelections     StrikeSelection[]
  trades               Trade[]

  @@index([userId])
  @@index([type])
}

model Trade {
  id              String      @id @default(cuid())
  userId          String
  brokerId        String
  instrumentName  String
  exchange        String?
  symbol          String?
  instrumentToken String?
  side            TradeSide
  quantity        Int
  price           Float?
  orderType       OrderType   @default(MARKET)
  status          TradeStatus @default(PENDING)
  brokerOrderId   String?
  errorMessage    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  broker          Broker      @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brokerId])
  @@index([status])
}

model PaperTrade {
  id              String           @id @default(cuid())
  userId          String
  brokerId        String
  symbol          String
  optionSymbol    String
  instrumentToken Int
  strike          Float
  optionType      String
  expiryDate      String
  signalType      SignalType
  strategy        String
  signalReason    String?
  entryPrice      Float
  entryTime       DateTime         @default(now())
  quantity        Int              @default(1)
  exitPrice       Float?
  exitTime        DateTime?
  stopLoss        Float
  target1         Float
  target2         Float
  target3         Float
  t1Hit           Boolean          @default(false)
  status          PaperTradeStatus @default(ACTIVE)
  pnl             Float            @default(0)
  pnlPercentage   Float            @default(0)
  marginPoints    Int?
  interval        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  broker          Broker           @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brokerId])
  @@index([status])
  @@index([entryTime])
  @@index([symbol])
}

model Signal {
  id              String     @id @default(cuid())
  userId          String
  brokerId        String?
  symbol          String
  optionSymbol    String
  instrumentToken Int
  strike          Float
  optionType      String
  expiryDate      String
  signalType      SignalType
  strategy        String
  signalReason    String
  signalTime      String
  signalDate      DateTime
  entryPrice      Float
  stopLoss        Float
  target1         Float
  target2         Float
  target3         Float
  ltp             Float?
  marginPoints    Int?
  interval        String?
  targetDate      String?
  tradeCreated    Boolean    @default(false)
  paperTradeId    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  confidenceGrade String?
  confidenceScore Int?
  broker          Broker?    @relation(fields: [brokerId], references: [id])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brokerId])
  @@index([signalDate])
  @@index([strategy])
  @@index([symbol])
  @@index([tradeCreated])
}

model Instrument {
  id              String   @id @default(cuid())
  instrumentToken Int      @unique
  exchangeToken   Int
  tradingsymbol   String
  name            String?
  lastPrice       Float    @default(0)
  expiry          String?
  strike          Float    @default(0)
  tickSize        Float
  lotSize         Int
  instrumentType  String
  segment         String
  exchange        String
  lastSeenDate    DateTime @default(now())
  firstSeenDate   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tradingsymbol])
  @@index([instrumentToken])
  @@index([name])
  @@index([exchange])
  @@index([segment])
  @@index([instrumentType])
  @@index([expiry])
  @@index([strike])
  @@index([lastSeenDate])
}

model TradingSettings {
  id                      String   @id @default(cuid())
  userId                  String
  symbol                  String
  hedgeLots               Int      @default(1)
  sellLots                Int      @default(1)
  paperLots               Int      @default(1)
  bufferPoints            Float    @default(5)
  liveEnabled             Boolean  @default(false)
  minSellRsi              Float    @default(45)
  maxSellRiskPts          Float    @default(25)
  placeQtyBasedOnSL       Boolean  @default(false)
  perTradeLoss            Float    @default(20000)
  perDayLoss              Float    @default(40000)
  enableNiftyTrendFilter  Boolean  @default(false)
  enableConfluenceChecker Boolean  @default(false)
  deduplicateSignals      Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
  @@index([symbol])
}

model LiveTrade {
  id                String          @id @default(cuid())
  userId            String
  brokerId          String
  symbol            String
  optionSymbol      String
  instrumentToken   Int
  strike            Float
  optionType        String
  expiryDate        String
  exchange          String          @default("NFO")
  lotSize           Int             @default(75)
  strategy          String
  signalId          String?
  hedgeSymbol       String?
  hedgeOrderId      String?
  hedgePrice        Float?
  hedgeQty          Int             @default(0)
  hedgeFilled       Boolean         @default(false)
  entryOrderId      String?
  entryPrice        Float?
  entryLimitPrice   Float?
  entryFilledPrice  Float?
  entryFilledTime   DateTime?
  entryQty          Int             @default(0)
  entryFilled       Boolean         @default(false)
  targetOrderId     String?
  targetPrice       Float?
  targetFilled      Boolean         @default(false)
  targetFilledPrice Float?
  targetFilledTime  DateTime?
  slOrderId         String?
  slPrice           Float?
  slFilled          Boolean         @default(false)
  slFilledPrice     Float?
  slFilledTime      DateTime?
  status            LiveTradeStatus @default(PENDING_HEDGE)
  pnl               Float?
  exitPrice         Float?
  exitTime          DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  broker            Broker          @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brokerId])
  @@index([status])
  @@index([optionSymbol])
  @@index([strategy])
}

model StrikeSelection {
  id                String   @id @default(cuid())
  brokerId          String
  symbol            String
  date              String
  expiry            String
  niftySpotAtOpen   Float
  atmStrike         Int
  ceTradingSymbol   String
  ceStrike          Int
  ceInstrumentToken Int
  peTradingSymbol   String
  peStrike          Int
  peInstrumentToken Int
  selectedAt        DateTime @default(now())
  broker            Broker   @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@unique([brokerId, symbol, date])
  @@index([brokerId])
  @@index([date])
}

model StrategyConfig {
  id           Int      @id @default(autoincrement())
  strategyName String   @unique
  configJson   String   @default("{}")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model CandleCache {
  id              Int      @id @default(autoincrement())
  instrumentToken Int
  dateStr         String
  interval        String
  candlesJson     String
  createdAt       DateTime @default(now())
  tradingsymbol   String   @default("")
  savedAt         DateTime @default(now())

  @@unique([instrumentToken, dateStr, interval])
  @@index([instrumentToken])
  @@index([tradingsymbol])
  @@index([dateStr])
}

// ─── AI Advisor Dataset Models ────────────────────────────────────────────────

/// Raw modeFull tick data — one row per WebSocket tick (batched writes).
/// This is the primary time-series dataset for future ML training.
model TickSnapshot {
  id              Int      @id @default(autoincrement())
  instrumentToken Int
  tradingsymbol   String
  tradeDate       String   // "YYYY-MM-DD" IST — for daily grouping
  timestamp       DateTime
  ltp             Float
  oi              Int      @default(0)
  oiDayHigh       Int      @default(0)
  oiDayLow        Int      @default(0)
  volume          Int      @default(0)
  buyQty          Int      @default(0) // total bid depth qty
  sellQty         Int      @default(0) // total ask depth qty
  avgPrice        Float    @default(0)
  isExpiry        Boolean  @default(false)

  @@index([instrumentToken, tradeDate])
  @@index([tradeDate])
}

/// 5-minute PCR + OI state captured via Kite Quote API.
/// Provides a structured view of CE vs PE OI balance over time.
model OiSnapshot {
  id         Int      @id @default(autoincrement())
  symbol     String   // "NIFTY"
  strike     Float
  expiryDate String
  tradeDate  String
  timestamp  DateTime
  ceOI       Int      @default(0)
  peOI       Int      @default(0)
  pcr        Float    @default(0) // peOI / ceOI
  ceLTP      Float    @default(0)
  peLTP      Float    @default(0)

  @@index([symbol, strike, tradeDate])
  @@index([tradeDate])
}

/// Named pattern instances detected in real-time from the rolling tick window.
/// Confirmed after 5/15 min to build accuracy statistics.
model PatternEvent {
  id              Int      @id @default(autoincrement())
  instrumentToken Int
  tradingsymbol   String
  tradeDate       String
  detectedAt      DateTime
  patternType     String   // OI_VELOCITY_SPIKE | ABSORPTION | ORDER_BOOK_FLIP_BULLISH | ORDER_BOOK_FLIP_BEARISH
  ltpAtDetection  Float
  oiAtDetection   Int      @default(0)
  ltpAfter5m      Float?   // filled by scheduler 5 min later
  ltpAfter15m     Float?   // filled by scheduler 15 min later
  wasCorrect      Boolean? // confirmed retrospectively

  @@index([instrumentToken, tradeDate])
  @@index([patternType])
  @@index([tradeDate])
}

/// Per-trade OI context captured at entry and exit.
/// This becomes the supervised ML training set: features → outcome.
model TradeOutcome {
  id               String   @id @default(cuid())
  liveTradeId      String?
  signalId         String?
  symbol           String
  optionSymbol     String
  direction        String   // SELL | BUY
  tradeDate        String
  isExpiry         Boolean  @default(false)
  // ── Entry snapshot ───────────────────────────────────────────────────────
  entryPrice       Float
  entryOI          Int      @default(0)
  entryPCR         Float?
  entryOIVelocity  Float?   // OI change per tick at entry time
  entryBuyQty      Int?
  entrySellQty     Int?
  entryVolume      Int?
  entryNiftyLTP    Float?
  // ── Exit snapshot ────────────────────────────────────────────────────────
  exitPrice        Float?
  exitOI           Int?
  exitPCR          Float?
  exitOIVelocity   Float?
  exitNiftyLTP     Float?
  // ── Result ───────────────────────────────────────────────────────────────
  outcome          String?  // TARGET_HIT | SL_HIT | MANUAL_EXIT | EARLY_EXIT
  pnl              Float?
  holdMinutes      Int?
  exitReason       String?  // OI_VELOCITY_SPIKE | ORDER_BOOK_FLIP | MANUAL | SL | TARGET
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([symbol, tradeDate])
  @@index([outcome])
  @@index([tradeDate])
  @@index([liveTradeId])
}

enum Role {
  USER
  ADMIN
}

enum BrokerType {
  KITE
  ANGEL
  DELTA
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  PLACED
  EXECUTED
  CANCELLED
  FAILED
}

enum PaperTradeStatus {
  ACTIVE
  CLOSED_SL
  CLOSED_TARGET1
  CLOSED_TARGET2
  CLOSED_TARGET3
  CLOSED_BE
  CLOSED_EOD
  CANCELLED
}

enum SignalType {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum LiveTradeStatus {
  PENDING_HEDGE
  PENDING_ENTRY
  PENDING_EXIT_ORDERS
  ACTIVE
  TARGET_HIT
  SL_HIT
  SQUARED_OFF
  FAILED
  CANCELLED
}
